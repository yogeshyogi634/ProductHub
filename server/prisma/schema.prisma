generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URL")
}

// ─── Users ───
model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  name         String?
  department   String?
  avatarUrl    String?
  role         Role     @default(EMPLOYEE)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  updates       Update[]
  votes         Vote[]
  feedbacks     Feedback[]
  replies       Reply[]
  otps          OTP[]
  statusHistory UpdateStatusHistory[]
}

enum Role {
  ADMIN
  MANAGEMENT
  EMPLOYEE
}

// ─── Products (5 internal products) ───
model Product {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())

  updates   Update[]
  feedbacks Feedback[]
}

// ─── Product Updates ───
model Update {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  status      UpdateStatus @default(WIP)
  productId   String       @db.ObjectId
  authorId    String       @db.ObjectId
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  product       Product              @relation(fields: [productId], references: [id])
  author        User                 @relation(fields: [authorId], references: [id])
  votes         Vote[]
  statusHistory UpdateStatusHistory[]
}

enum UpdateStatus {
  WIP
  IN_REVIEW
  RESOLVED
  DONE
  PLANNED
  SHIPPED
  DEPRECATED
  ON_HOLD
  CANCELLED
}

// ─── Votes (upvote/downvote) ───
model Vote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      VoteType
  userId    String   @db.ObjectId
  updateId  String   @db.ObjectId
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  update Update @relation(fields: [updateId], references: [id])

  @@unique([userId, updateId])
}

enum VoteType {
  UP
  DOWN
}

// ─── Update Status History ───
model UpdateStatusHistory {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  updateId  String       @db.ObjectId
  fromStatus UpdateStatus?
  toStatus  UpdateStatus
  changedBy String       @db.ObjectId
  reason    String?
  createdAt DateTime     @default(now())

  update Update @relation(fields: [updateId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [changedBy], references: [id])

  @@index([updateId, createdAt])
}

// ─── Feedback Wall ───
model Feedback {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  message   String
  productId String   @db.ObjectId
  authorId  String   @db.ObjectId
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])
  replies Reply[]

  @@index([productId, createdAt])
}

// ─── Replies to Feedback ───
model Reply {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    String
  feedbackId String   @db.ObjectId
  authorId   String   @db.ObjectId
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id])
  author   User     @relation(fields: [authorId], references: [id])

  @@index([feedbackId, createdAt])
}

// ─── OTP for Authentication ───
model OTP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  userId    String?  @db.ObjectId
  attempts  Int      @default(0)
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email, isUsed, expiresAt])
}
